{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Poetry Uvicorn",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/uvicorn", 
            "args": [
                "src.main:app",
                "--reload"
            ],
            "cwd": "${workspaceFolder}",
            "jinja": true,
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}" 
            }
        }
    ]
}